# Backend LLM: 'cloud' (Groq) atau 'local' (PyTorch)
LLM_BACKEND=cloud

# Groq API (https://console.groq.com/keys)
LLM_API_KEY=your_groq_api_key_here

# Endpoint Groq (sudah default, ubah jika pakai OpenAI/OpenRouter)
LLM_API_BASE=https://api.groq.com/openai/v1

# Model ID Groq: llama-3.2-3b-preview, llama-3.1-8b-instant, llama-3.3-70b-versatile
LLM_API_MODEL=llama-3.2-3b-preview
